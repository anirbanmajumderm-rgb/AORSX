generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id              Int          @id @default(autoincrement())
  username        String       @unique
  email           String       @unique
  password        String
  name            String
  image           String?
  role            String       @default("admin")
  twoFactorEnabled Boolean     @default(false)
  twoFactorSecret String?
  twoFactorBackupCodes String[]
  twoFactorVerifiedAt DateTime?
  email2FAEnabled   Boolean     @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Company {
  id          Int      @id @default(autoincrement())
  name        String   @default("Portfolio")
  tagline     String   @default("AI SaaS Agency")
  description String?
  aboutText   String?
  vision      String?
  mission     String?
  logo        String?
  favicon     String?
  founderName String?
  founderRole String?
  founderBio  String?
  founderImage String?
  email       String?
  phone       String?
  address     String?
  linkedin    String?
  twitter     String?
  github      String?
  updatedAt   DateTime @updatedAt
}

model SocialLink {
  id    Int    @id @default(autoincrement())
  platform String
  url   String
  icon  String?
  order Int    @default(0)
}

model Skill {
  id          Int      @id @default(autoincrement())
  category    String
  name        String
  proficiency Int      @default(0)
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model Project {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  description  String?
  content      String?
  technologies String?
  clientName   String?
  companyName  String?
  projectUrl   String?
  githubUrl    String?
  category     String?
  image        String?
  featured     Boolean  @default(false)
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reviews      Review[]

  @@index([isActive])
  @@index([slug])
  @@index([order, createdAt])
}

model Review {
  id           Int      @id @default(autoincrement())
  projectId    Int
  reviewerName String
  reviewerEmail String?
  rating       Int      @default(5)
  reviewText   String?
  isApproved   Boolean  @default(false)
  isSpam       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([isApproved, isSpam])
  @@index([projectId])
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

model Question {
  id            Int      @id @default(autoincrement())
  visitorName   String
  visitorEmail  String
  visitorPhone  String?
  question      String
  adminReply    String?
  isImportant   Boolean  @default(false)
  isSpam        Boolean  @default(false)
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([isSpam])
}

model Contact {
  id           Int      @id @default(autoincrement())
  type         String
  value        String
  label        String?
  icon         String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, order])
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, order])
}

model WhyChooseMe {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, order])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String?
  type  String @default("text")
}

model UploadedFile {
  id           Int      @id @default(autoincrement())
  originalName String
  storedName   String
  filePath     String
  fileType     String?
  fileSize     Int?
  uploadType   String   @default("other")
  createdAt    DateTime @default(now())
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  roleId    Int?
  role      Role?    @relation(fields: [roleId], references: [id])
  status    String   @default("active")
  avatar    String?
  lastActive DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feature {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  name      String
  description String?
  enabled   Boolean  @default(false)
  category  String   @default("core")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int        @id @default(autoincrement())
  adminId   Int?
  type      String     @default("info")
  title     String
  description String?
  read      Boolean    @default(false)
  link      String?
  createdAt DateTime   @default(now())

  @@index([adminId, read])
  @@index([createdAt])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  subject   String
  body      String
  variables String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  to        String
  subject   String
  template  String?
  status    String   @default("pending")
  error     String?
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  adminId   Int
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([expiresAt])
}

model RateLimit {
  id        Int      @id @default(autoincrement())
  key       String
  count     Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([key, expiresAt])
}

model Automation {
  id        Int      @id @default(autoincrement())
  name      String
  description String?
  trigger   String   @default("schedule")
  status    String   @default("active")
  config    String?
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Role {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  users       AdminUser[]
  permissions String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model WebsiteControl {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  name      String
  description String?
  enabled   Boolean  @default(true)
  category  String   @default("system")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  name      String
  key       String   @unique
  status    String   @default("active")
  lastUsedAt DateTime?
  requests  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  detail    String?
  type      String   @default("info")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model EmailOTP {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([email, used, expiresAt])
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  event     String
  category  String   @default("pageview")
  label     String?
  value     Float?
  metadata  String?
  createdAt DateTime @default(now())
}

model TeamMember {
  id         Int      @id @default(autoincrement())
  name       String
  role       String
  bio        String?
  photo      String?
  email      String?
  phone      String?
  linkedin   String?
  twitter    String?
  github     String?
  displayOrder Int   @default(0)
  isFounder  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, displayOrder])
}

model VisitorSession {
  id        String   @id @default(cuid())
  visitorId String
  page      String?
  referrer  String?
  userAgent String?
  ip        String?
  startedAt DateTime @default(now())
  lastSeen  DateTime @updatedAt
  endedAt   DateTime?

  @@index([visitorId])
  @@index([lastSeen])
}

model PageView {
  id        Int      @id @default(autoincrement())
  page      String
  referrer  String?
  country   String?
  device    String?
  visitorId String?
  createdAt DateTime @default(now())

  @@index([page, createdAt])
  @@index([visitorId])
  @@index([createdAt])
}

model Interaction {
  id        Int      @id @default(autoincrement())
  type      String   @default("click")
  page      String?
  label     String?
  metadata  String?
  visitorId String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int?
  action     String
  resource   String?
  resourceId Int?
  details    String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([resource, createdAt])
  @@index([adminId])
  @@index([createdAt])
}

model NotificationPreference {
  id            Int  @id @default(autoincrement())
  adminId       Int
  newUserSignup    Boolean @default(true)
  newFaqSubmission Boolean @default(true)
  newContactSubmission Boolean @default(true)
  analyticsAnomaly  Boolean @default(false)
  failedLogin      Boolean @default(true)
  contentPublish   Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([adminId])
}

model FeatureFlag {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedBy   Int?

  @@index([enabled])
}

model Conversation {
  id        String   @id @default(cuid())
  visitorId String
  name      String?
  email     String?
  status    String   @default("active")
  unread    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]

  @@index([visitorId])
  @@index([status])
  @@index([updatedAt])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String       @default("visitor")
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}


