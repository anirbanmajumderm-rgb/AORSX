# ─── Database ─────────────────────────────────────────
# PostgreSQL (Neon for production, Vercel):
# Replace with your actual Neon connection string
DATABASE_URL=postgresql://user:password@ep-example.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth (Required for admin authentication) ─────
# CRITICAL: Use a STRONG random 64-char string. The default is INSECURE.
# Generate one:
#   PowerShell:  [System.Convert]::ToBase64String((1..48|%{Get-Random -Max 256}))
#   Linux/Mac:   openssl rand -base64 48
#   Node.js:     node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
NEXTAUTH_SECRET=change-this-to-a-random-64-char-string
NEXTAUTH_URL=http://localhost:3000

# ─── Email (SMTP) ─────────────────────────────────────
# Required for password reset, notifications, and alerts.
# Uncomment and configure for email delivery:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# EMAIL_FROM="Your Name <noreply@yourdomain.com>"

# ─── Optional ─────────────────────────────────────────
# LOG_LEVEL=debug            # debug | info | warn | error

# ─── Vercel Deployment ────────────────────────────────
# Set these in Vercel dashboard (Project Settings → Environment Variables):
#   DATABASE_URL        — Neon PostgreSQL connection string
#   NEXTAUTH_SECRET     — Secure random string (openssl rand -base64 48)
#   NEXTAUTH_URL        — Your Vercel deployment URL (e.g., https://your-project.vercel.app)
#   SMTP_HOST           — Gmail: smtp.gmail.com
#   SMTP_PORT           — 587
#   SMTP_USER           — Gmail address
#   SMTP_PASS           — Gmail app password
#   EMAIL_FROM          — "Your Name <noreply@yourdomain.com>"
#   NEXT_TELEMETRY_DISABLED — 1
