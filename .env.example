# ─── Database ─────────────────────────────────────────
# PostgreSQL (Neon for production, Vercel):
# Replace with your actual Neon connection string
DATABASE_URL=postgresql://neondb_owner:npg_8XJjsVIHfcb4@ep-rough-lab-ao9rybtf.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ─── NextAuth (Required for admin authentication) ─────
# Generate a secure random 64-char string:
#   PowerShell:  [System.Convert]::ToBase64String((1..48|%{Get-Random -Max 256}))
#   Linux/Mac:   openssl rand -base64 48
NEXTAUTH_SECRET=change-this-to-a-random-64-char-string
NEXTAUTH_URL=http://localhost:3000

# ─── Email (SMTP) ─────────────────────────────────────
# Required for password reset, notifications, and alerts.
# Uncomment and configure for email delivery:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# EMAIL_FROM="Your Name <noreply@yourdomain.com>"

# ─── Optional ─────────────────────────────────────────
# LOG_LEVEL=debug            # debug | info | warn | error
# NEXT_TELEMETRY_DISABLED=1  # Disable Next.js telemetry

# ─── Production Overrides ─────────────────────────────
# NEXTAUTH_URL=https://yourdomain.com
# NEXTAUTH_SECRET=<production-secret>
